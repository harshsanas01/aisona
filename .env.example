# Operating modes
CARECALL_STORAGE_MODE=memory
CARECALL_RETRIEVAL_MODE=hybrid
CARECALL_ANSWER_MODE=mock

# OpenAI (only used when CARECALL_ANSWER_MODE=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Retrieval tuning
CARECALL_LEXICAL_WEIGHT=0.45
CARECALL_SEMANTIC_WEIGHT=0.55
CARECALL_TOP_K=8
CARECALL_MIN_RELEVANCE_SCORE=0.15

# PostgreSQL (only used when CARECALL_STORAGE_MODE=postgres)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/carecall

BACKEND_PORT=8000
